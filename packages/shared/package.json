{
  "name": "@bucketdrive/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/*": "./src/schemas/*",
    "./contracts/*": "./src/contracts/*",
    "./db/*": "./src/db/*"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test:unit": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.45.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
